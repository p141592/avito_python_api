                    "error"
                  ],
                  "type": "object"
                }
              }
            },
            "description": "Внутренняя ошибка"
          }
        },
        "security": [
          {
            "ClientCredentials": []
          }
        ],
        "summary": "Получение соответствия переданной цены рыночной цене",
        "x-rate-limiter": {
          "default": 60
        }
      }
