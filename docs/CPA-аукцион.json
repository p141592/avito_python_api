            "type": "string"
          }
        },
        "required": [
          "message"
        ],
        "type": "object"
      },
      "tooManyRequestsError": {
        "properties": {
          "error": {
            "properties": {
              "code": {
                "description": "Код ошибки",
                "example": 429,
                "format": "int32",
                "type": "integer"
              }
            },
            "required": [
              "code"
            ],
            "type": "object"
          }
        },
        "type": "object"
      }
